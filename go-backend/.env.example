# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/estate_docs_dev

# JWT
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com

# File Storage
UPLOAD_DIR=./temp_uploads
GENERATED_DIR=./generated
DOCUMENT_UPLOADS_DIR=./document_uploads
MAX_UPLOAD_SIZE_MB=10

# OpenAI
OPENAI_API_KEY=

# Environment
ENVIRONMENT=development
DEBUG=true

# Cookie
COOKIE_SECURE=false

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3005,https://www.estate-doctor.com

# Server
PORT=8005
